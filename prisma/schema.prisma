// مخطط قاعدة البيانات - MyNet Web
// المرحلة 1: نمذجة كاملة للجداول المقابلة لبرنامج MyNet.v4
// ملاحظة: نحتفظ بالمعرّفات الأصلية (id) لتبقى العلاقات صحيحة بعد النقل.
// المفاتيح الأجنبية حقول Int بسيطة (كما في الأصل) لضمان نقل مرن دون فشل بسبب سجلات يتيمة.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ===== المستخدمون والصلاحيات =====
enum Role {
  ADMIN
  ACCOUNTANT
  CASHIER
  TECHNICIAN
  VIEWER
}

// ===== الوكيل (المستأجر): مالك النظام يدير عدّة وكلاء، كل وكيل يدير مكاتبه =====
model Agent {
  id         Int       @id @default(autoincrement())
  name       String // اسم/علامة الوكيل — يظهر بكامل البرنامج له
  officeCap  Int       @default(1) // أقصى عدد مكاتب يسمح له بإنشائها
  planExpiry DateTime? // تاريخ انتهاء الاشتراك (null = بلا انتهاء)
  isTrial    Boolean   @default(false) // حساب تجريبي (أسبوع)
  approved   Boolean   @default(true) // موافقة المالك — التجريبي يبدأ false حتى يوافق المالك
  backupEmail String? // إيميل النسخ الاحتياطي/الاسترجاع — تُرسل إليه نسخة يومية
  // فترة احتساب رواتب الموظفين (عامة لكل مكاتب الوكيل) — يضبطها المدير ويغيّرها متى شاء
  salaryPeriodFrom String? // (مهجور) YYYY-MM-DD — بداية الفترة بالتاريخ الكامل (النموذج القديم)
  salaryPeriodTo   String? // (مهجور) YYYY-MM-DD — نهاية الفترة بالتاريخ الكامل (النموذج القديم)
  salaryFromDay    Int? // يوم بداية الفترة (1-31) — متكرّرة كل شهر بلا شهر/سنة
  salaryToDay      Int? // يوم نهاية الفترة في الشهر التالي (1-31)
  lastBackupDate   String? // آخر يومٍ (بغداد) أُرسلت فيه النسخة اليومية — يمنع الازدواج بين السحابة والحاسبة
  isDeleted  Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @default(now()) @updatedAt

  @@map("agents")
}

model User {
  id        Int      @id @default(autoincrement())
  fullName  String
  username  String   @unique
  password  String
  plainPassword String? // نسخة قابلة للعرض للمالك (تُضبط عند إنشاء/تعيين المالك للكلمة)
  recoveryEmail String? // إيميل استرجاع كلمة السر (يُستخدم للمالك؛ المدير يستخدم Agent.backupEmail)
  resetToken String? // رمز إعادة تعيين كلمة السر (مؤقّت)
  resetExpiry DateTime? // انتهاء صلاحية رمز إعادة التعيين
  role      Role     @default(VIEWER)
  isAdmin   Boolean  @default(false) // مدير كامل الصلاحيات
  isOwner   Boolean  @default(false) // مالك النظام (فوق المدير) — يدير الوكلاء فقط
  agentId   Int? // الوكيل (المستأجر) الذي ينتمي إليه هذا المستخدم
  permissions String? // صلاحيات مفصولة بفواصل
  towerId   Int? // البرج الذي يتحكم به هذا المستخدم (المكتب)
  managerPhone String? // رقم المدير لإرسال التقرير اليومي
  fcmToken  String? // رمز جهاز FCM (التطبيق الأصلي) — لإشعارات الهاتف حين لا يدعم المتصفح Web Push
  isActive  Boolean  @default(true)
  isDeleted Boolean  @default(false)
  failedAttempts Int   @default(0) // محاولات دخول فاشلة متتالية (لمنع التخمين)
  lockedUntil DateTime? // قفل الحساب مؤقتاً بعد محاولات كثيرة
  legacyId  Int? // معرّف المستخدم في البرنامج القديم
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  auditLogs AuditLog[]

  @@map("users")
}

model AuditLog {
  id        Int      @id @default(autoincrement())
  userId    Int?
  action    String
  entity    String?
  entityId  String?
  details   String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  updatedAt DateTime @default(now()) @updatedAt // تتبّع التغييرات للمزامنة
  @@map("audit_logs")
}

// ===== المجموعات (group_brig) =====
model Group {
  id        Int     @id @default(autoincrement())
  name      String?
  balance   Float   @default(0)
  isDeleted Boolean @default(false)

  updatedAt DateTime @default(now()) @updatedAt // تتبّع التغييرات للمزامنة
  @@map("groups")
}

// ===== الأبراج / القواطع (brig) =====
model Tower {
  id          Int     @id @default(autoincrement())
  name        String?
  agentId     Int? // الوكيل (المستأجر) الذي يملك هذا المكتب
  address     String?
  note        String?
  phone       String?
  loginUrl    String? // رابط لوحة SAS4 (الدخول)
  activationTemplate String? // قالب رابط تفعيل المشترك، مثال: http://sas/admin?user={user}
  username    String? // اسم مستخدم الدخول للوحة SAS4
  password    String?
  passOnline  String?
  type        Int?
  price       Int?
  nesba       Int? // النسبة
  groupId     Int?
  isMain      Int?
  allowAdd    Int?
  allowSms    Int?
  month       Int?
  activationMode String? @default("month") // نظام التفعيل: month = نفس تاريخ اليوم بالشهر التالي، days30 = 30 يوماً
  managerPhone String? // رقم مدير هذا المكتب (لإرسال التقرير اليومي)
  mapArea     String? // رمز منطقة الخريطة لهذا المكتب (مثل MWA/ENT/SLM/KAD...) لتحديد مواقع المشتركين
  rewardsEnabled String? @default("0") // 1 = تفعيل نظام مكافآت المشتركين لهذا المكتب
  silent      String? @default("1") // 1 = إرسال صامت افتراضي لهذا المكتب
  waEnabled   String? @default("1") // 1 = تفعيل واتساب لهذا المكتب
  syncEnabled String? @default("0") // 1 = تفعيل المزامنة اليومية التلقائية
  syncTime    String? // وقت مزامنة الاشتراكات اليومية مع SAS (HH:MM)
  lastReminderDate String? // آخر يوم (YYYY-MM-DD) أُرسل/عولج فيه تذكير الانتهاء (لمنطق الموافقة عند الدخول)
  lastReportDate String? // آخر يوم (YYYY-MM-DD) أُرسل فيه التقرير اليومي للمدير (لمنع تكراره)
  // موقع المكتب للبصمة الجغرافية (الفني لا يبصم إلا داخل النطاق)
  lat         Float? // خط العرض
  lng         Float? // خط الطول
  geoRadius   Int?    @default(200) // نصف قطر النطاق المسموح بالأمتار
  geoEnabled  Boolean @default(false) // تفعيل التحقّق من الموقع عند البصمة
  isDeleted   Boolean @default(false)

  updatedAt DateTime @default(now()) @updatedAt // تتبّع التغييرات للمزامنة
  @@index([groupId])
  @@map("towers")
}

// ===== معلومات البرج الفنية (brgInfo) =====
model TowerInfo {
  id         Int     @id @default(autoincrement())
  sector     String?
  towerId    Int? // brg_fk
  ip         String?
  username   String?
  password   String?
  type       String?
  userCount  Int?
  channel    String?
  company    String?
  address    String?
  notes      String?
  isDeleted  Boolean @default(false)

  updatedAt DateTime @default(now()) @updatedAt // تتبّع التغييرات للمزامنة
  @@index([towerId])
  @@map("tower_info")
}

// ===== الباقات (card) =====
model Package {
  id          Int     @id @default(autoincrement())
  agentId     Int? // الوكيل (المستأجر) مالك هذا الإعداد
  name        String?
  priceDollar Float? // card_priceDO
  priceDinar  Float?
  addPrice    Float? // card_add
  cardCost    Float? // سعر شراء/كلفة الكارت الواحد لهذه الفئة (لديون الكارتات)
  rewardAmount Int? // مبلغ مكافأة التفعيل لهذه الباقة (لكل شهر) — نظام أكواد المكافآت
  towerId     Int? // card_brigfk
  isDeleted   Boolean @default(false)

  updatedAt DateTime @default(now()) @updatedAt // تتبّع التغييرات للمزامنة
  @@index([towerId])
  @@map("packages")
}

// ===== المشتركون (costumer) =====
model Subscriber {
  id           Int       @id @default(autoincrement())
  name         String?
  phone        String?
  address      String?
  packageId    Int? // cost_cardFk
  note         String?
  dateFrom     DateTime?
  dateTo       DateTime?
  towerId      Int? // cost_bregFk
  groupId      Int? // cost_GroupFk
  month        Int?
  money        Float?
  wasel        Float? // المبلغ الواصل
  carry        Float? // الدين المرحّل
  sector       String?
  state        String?
  type         Int?
  smsEnabled   Int? // cost_sms
  waEnabled    Boolean @default(true) // إرسال واتساب لهذا المشترك (افتراضي مفعّل)
  createdByUser String? // cost_user
  createdByName String? // cost_userName
  wifiUser     String?
  wifiPass     String?
  netUser      String? // اسم مستخدم المشترك في SAS4
  transferredAt DateTime? // وقت تحويل يوزره عبر تكت تحويل (يُنبَّه عند التفعيل، ويُحذف بعد 30 يوماً دون تفعيل)
  transferredTo String? // اليوزر الجديد بعد التحويل (للتنبيه)
  rewardCode   String? // كود المكافأة الحالي (8 خانات) — نظام أكواد المكافآت
  rewardBalance Int?  @default(0) // رصيد المكافأة المتراكم (يُخصم عند الاستخدام)
  sasId        Int? // معرّف المشترك في SAS4 (للربط والتفعيل)
  cardCode     String? // cardID
  // حقول شاشة المشترك التفصيلية
  subPassword  String? // باسورد الاشتراك
  userNano     String? // يوزر الناتو
  passNano     String? // باسورد الناتو
  ipNano       String? // ايبي الناتو
  ftth         String? // معرّف ftth
  telegram     String? // التلكرام
  employee     String? // الموظف / قسم الحسابات
  tele         String?
  mac          String?
  affiliate    String?
  lastSmsDate  DateTime?
  isDeleted    Boolean   @default(false)

  updatedAt DateTime @default(now()) @updatedAt // تتبّع التغييرات للمزامنة
  @@index([packageId])
  @@index([towerId])
  @@index([groupId])
  @@index([phone])
  @@index([name])
  @@index([isDeleted, towerId, name]) // يطابق فلترة+ترتيب قائمة المشتركين
  @@index([towerId, netUser]) // مطابقة اليوزر السريعة لسحب كود المكافأة
  @@map("subscribers")
}

// ===== الحسابات (acounts) =====
model Account {
  id        Int     @id @default(autoincrement())
  name      String?
  notes     String?
  type      Int?
  typeName  String?
  userId    Int?
  isEmployee Boolean @default(false) // حساب موظف (تنظيمي) — يبقى يؤثر على التقرير اليومي
  towerId   Int? // المكتب المالك للحساب (قائمة حسابات مستقلة لكل مكتب؛ المدير يرى الكل)
  isDeleted Boolean @default(false)

  updatedAt DateTime @default(now()) @updatedAt // تتبّع التغييرات للمزامنة
  @@index([towerId])
  @@map("accounts")
}

// ===== وصولات التفعيل والتجديد (Sand) =====
model SubscriptionEntry {
  id           Int       @id @default(autoincrement())
  date         DateTime?
  notes        String?
  dateFrom     DateTime?
  dateTo       DateTime?
  money        Float?
  moneyIn      Float?
  moneyCarry   Float?
  moneyType    Int?
  cardType     String?
  withdrawal   Float?
  priceDollar  Float?
  deposit      Float?
  balance      Float?
  operation    String?
  subscriberId Int? // Sand_cosFk
  month        String?
  card2        String?
  withdrawalIq Float?
  towerId      Int? // Sand_fkBrig
  nextDate     DateTime?
  userId       Int?
  pushType     String?
  createdByUser String? // sand_user
  addPrice     Float? // Sand_add
  isMaster     Boolean   @default(false) // تفعيل ماستر (واصل كامل، ويُسجَّل بحساب الماستر المستقل)
  isDeleted    Boolean   @default(false)

  updatedAt DateTime @default(now()) @updatedAt // تتبّع التغييرات للمزامنة
  @@index([subscriberId])
  @@index([towerId])
  @@index([date])
  @@map("subscription_entries")
}

// ===== الحركات المالية (money) =====
model MoneyTx {
  id         Int       @id @default(autoincrement())
  moneyIn    Float?
  moneyOut   Float?
  accountId  Int? // money_acFk
  userId     Int?
  date       DateTime?
  notes      String?
  pc         String?
  serverDate DateTime?
  sourceType String? // مصدر الحركة: activation | invoice | debt | manual (لإلغائها عكسياً)
  sourceId   Int? // معرّف المصدر (وصل التفعيل/الفاتورة/المشترك)
  towerId    Int? // البرج/المكتب الذي تخصّه الحركة (لتقارير كل برج)
  salaryStatementId Int? // كشف الراتب الذي احتُسبت فيه هذه الحركة (لحساب الموظف) — يمنع تكرار احتسابها؛ لا تُحذف من التقرير اليومي
  isDeleted  Boolean   @default(false)

  updatedAt DateTime @default(now()) @updatedAt // تتبّع التغييرات للمزامنة
  @@index([accountId])
  @@index([date])
  @@index([sourceType, sourceId])
  @@index([towerId])
  @@map("money_tx")
}

// ===== الصندوق (box) =====
model Box {
  id        Int       @id @default(autoincrement())
  userId    Int?
  date      DateTime?
  idFrom    Int?
  idTo      Int?
  money     Float?
  type      Int?
  oldMoney  Float?
  notes     String?
  isDeleted Boolean   @default(false)

  updatedAt DateTime @default(now()) @updatedAt // تتبّع التغييرات للمزامنة
  @@map("boxes")
}

// ===== إيداعات/أقسام الصندوق (box_dep) =====
model BoxDep {
  id        Int     @id @default(autoincrement())
  name      String?
  type      Int?
  money     Float?
  isDeleted Boolean @default(false)

  updatedAt DateTime @default(now()) @updatedAt // تتبّع التغييرات للمزامنة
  @@map("box_deps")
}

// ===== كروت التفعيل (cards) =====
// ===== حساب مصروف/مقبوض المدير (لا يؤثر على التقرير اليومي) =====
model ManagerTx {
  id        Int      @id @default(autoincrement())
  type      String // expense | receipt | card-payment | salary
  amount    Float
  notes     String?
  date      DateTime @default(now())
  userId    Int?
  byUser    String? // اسم المدير الذي أجرى الحركة (للتدقيق — يبقى ولو حُذف المستخدم)
  agentId   Int? // الوكيل (المستأجر) مالك الحركة — عزل حسابات المدير بين الوكلاء
  isDeleted Boolean  @default(false)

  updatedAt DateTime @default(now()) @updatedAt // تتبّع التغييرات للمزامنة
  @@index([type])
  @@index([agentId])
  @@map("manager_tx")
}

model RechargeCard {
  id           Int       @id @default(autoincrement())
  agentId      Int? // الوكيل (المستأجر) مالك مخزون الكروت — عزل الكروت بين الوكلاء
  number       String?
  password     String?
  serial       String? // سيريال الكارت
  packageId    Int? // الفئة/الباقة (50/100/150 ميكا)
  price        Float? // سعر شراء/كلفة الكارت الواحد (لحساب ديون الكارتات)
  subscriberId Int? // المشترك الذي استُخدم له
  reservedBy   Int? // مستخدم حجز الكارت مؤقتاً (سحب كارت)
  reservedAt   DateTime? // وقت الحجز المؤقت
  useDate      DateTime? // تاريخ الاستخدام النهائي (null = متاح)
  addDate      DateTime?
  userId       Int?
  userName     String?

  updatedAt DateTime @default(now()) @updatedAt // تتبّع التغييرات للمزامنة
  @@index([serial])
  @@index([packageId, useDate])
  @@map("recharge_cards")
}

// ===== المواد / المخزن (items) =====
model Item {
  id          Int     @id @default(autoincrement())
  name        String?
  category    String?
  priceDinar  Float?
  priceDollar Float?
  priceSale   Float?
  priceSale2  Float?
  type        Int?
  barcode     String?
  count       Float?
  minCount    Int?
  color       String?
  size        String?
  towerId     Int? // المكتب المالك للمخزن (مخزن مستقل لكل مكتب؛ المدير يرى الكل)
  isDeleted   Boolean @default(false)

  updatedAt DateTime @default(now()) @updatedAt // تتبّع التغييرات للمزامنة
  @@index([towerId])
  @@map("items")
}

// ===== الفواتير (fatora) =====
model Invoice {
  id           Int       @id @default(autoincrement())
  date         DateTime?
  number       Int?
  itemsCount   Float?
  totalMy      Float?
  waselHim     Float?
  pushType     Int?
  note         String?
  user         String?
  type         String?
  subscriberId Int? // fatora_cosfk
  towerId      Int? // البرج/المكتب (لتقارير كل برج)
  isDeleted    Boolean   @default(false)

  updatedAt DateTime @default(now()) @updatedAt // تتبّع التغييرات للمزامنة
  @@index([subscriberId])
  @@index([towerId])
  @@map("invoices")
}

// ===== أصناف الفاتورة (item_fatora) =====
model InvoiceItem {
  id        Int     @id @default(autoincrement())
  invoiceId Int? // item_fatorafk
  itemId    Int? // item_fatora_itemfk
  count     Float?
  price     Float?
  buyPrice  Float?
  note      String?
  barcode   String?
  color     String?
  size      String?
  isDeleted Boolean @default(false)

  updatedAt DateTime @default(now()) @updatedAt // تتبّع التغييرات للمزامنة
  @@index([invoiceId])
  @@map("invoice_items")
}

// ===== التذاكر (tct) =====
model Ticket {
  id            Int       @id @default(autoincrement())
  agentId       Int? // الوكيل (المستأجر) مالك التذكرة — عزل البيانات
  createdByUser String?
  typeId        Int?
  priorityId    Int?
  statusId      Int?
  desc          String?
  note          String?
  tower         String?
  date          DateTime?
  dateClose     DateTime?
  isClosed      Int?
  closedByUser  String?
  depName       String?
  isDeleted     Boolean   @default(false)

  updatedAt DateTime @default(now()) @updatedAt // تتبّع التغييرات للمزامنة
  @@map("tickets")
}

model TicketType {
  id        Int     @id @default(autoincrement())
  name      String?
  isDeleted Boolean @default(false)

  updatedAt DateTime @default(now()) @updatedAt // تتبّع التغييرات للمزامنة
  @@map("ticket_types")
}

model TicketPriority {
  id        Int     @id @default(autoincrement())
  name      String?
  isDeleted Boolean @default(false)

  updatedAt DateTime @default(now()) @updatedAt // تتبّع التغييرات للمزامنة
  @@map("ticket_priorities")
}

model TicketState {
  id        Int     @id @default(autoincrement())
  name      String?
  isDeleted Boolean @default(false)

  updatedAt DateTime @default(now()) @updatedAt // تتبّع التغييرات للمزامنة
  @@map("ticket_states")
}

// ===== الأشهر (month) =====
model Month {
  id        Int       @id @default(autoincrement())
  name      String?
  notes     String?
  user      String?
  date      DateTime?
  month     String?
  money     Float?
  isDeleted Boolean   @default(false)

  updatedAt DateTime @default(now()) @updatedAt // تتبّع التغييرات للمزامنة
  @@map("months")
}

// ===== الملاحظات (notes) =====
model Note {
  id        Int       @id @default(autoincrement())
  name      String?
  text      String?
  date      DateTime?
  done      Int?
  category  String?
  desc      String?
  dateAlert DateTime?
  user      String?
  isDeleted Boolean   @default(false)

  updatedAt DateTime @default(now()) @updatedAt // تتبّع التغييرات للمزامنة
  @@map("notes")
}

// ===== الأحداث / التقويم (events) =====
model Event {
  id   Int       @id @default(autoincrement())
  name String?
  date DateTime?
  desc String?
  user String?

  updatedAt DateTime @default(now()) @updatedAt // تتبّع التغييرات للمزامنة
  @@map("events")
}

// ===== إعدادات النظام (Setting_system) =====
model SystemSetting {
  id    Int     @id @default(autoincrement())
  type  String?
  value String?
  text  String?

  updatedAt DateTime @default(now()) @updatedAt // تتبّع التغييرات للمزامنة
  @@map("system_settings")
}

// ===== قوالب الرسائل (Setting_sms) =====
model SmsTemplate {
  id     Int     @id @default(autoincrement())
  agentId Int? // الوكيل (المستأجر) مالك هذا الإعداد
  type   String?
  text   String?
  enable String?

  updatedAt DateTime @default(now()) @updatedAt // تتبّع التغييرات للمزامنة
  @@map("sms_templates")
}

// ===== سجل الرسائل الصادرة (SMS / واتساب / تيليغرام) =====
enum MessageChannel {
  SMS
  WHATSAPP
  TELEGRAM
}

enum MessageStatus {
  PENDING
  SENT
  FAILED
}

model Message {
  id            Int            @id @default(autoincrement())
  channel       MessageChannel @default(SMS)
  subscriberId  Int?
  phone         String?
  text          String
  status        MessageStatus  @default(PENDING)
  error         String?
  createdByUser String?
  date          DateTime       @default(now())

  updatedAt DateTime @default(now()) @updatedAt // تتبّع التغييرات للمزامنة
  @@index([subscriberId])
  @@index([status])
  @@map("messages")
}

// ===== أنواع الإشعار (pushType) =====
model PushType {
  id        Int     @id @default(autoincrement())
  type      String?
  isDeleted Boolean @default(false)

  updatedAt DateTime @default(now()) @updatedAt // تتبّع التغييرات للمزامنة
  @@map("push_types")
}

// ===== إدارة الفنيين (لوحات كانبان على نمط Trello) — ميزة جديدة مستقلّة =====
model TaskBoard {
  id        Int      @id @default(autoincrement())
  name      String
  towerId   Int? // المكتب المالك للّوحة (null = لوحة عامة/الإدارة). لوحة مستقلة لكل مكتب.
  createdAt DateTime @default(now())
  isDeleted Boolean  @default(false)

  updatedAt DateTime @default(now()) @updatedAt // تتبّع التغييرات للمزامنة
  @@index([towerId])
  @@map("task_boards")
}

// ===== الفنيون (لكل مكتب) — تُوجَّه لهم بطاقات إدارة الفنيين =====
model Technician {
  id        Int      @id @default(autoincrement())
  name      String
  phone     String?
  agentId   Int? // الوكيل (المستأجر) — للعزل ولتحديد الوكيل عند دخول الفني
  towerId   Int? // المكتب التابع له (null = غير محدّد)
  supportTowerId Int? // مكتب يدعمه هذا الفني مؤقتاً (يظهر ضمن فنّييه أيضاً)
  supportKind String? // نوع الدعم: "cards" بطاقات محدّدة | "day" يوم كامل
  sessionToken String? // جهاز واحد فقط: رمز آخر تسجيل دخول — الدخول من جهاز جديد يُبطل السابق
  supportCardIds String? // JSON بمعرّفات بطاقات الدعم (لنوع cards) — يعود تلقائياً عند إكمالها
  accountId Int? // حساب المصروفات/المقبوضات (موظف) المرتبط بهذا الفني في نفس مكتبه
  // ===== تطبيق إدارة الفنيين: الدخول والحضور والراتب =====
  username  String?  @unique // اسم مستخدم فريد على مستوى النظام (لدخول تطبيق الفني)
  code      String? // رمز الدخول (كلمة السر) مُشفّر bcrypt
  plainCode String? // نسخة قابلة للعرض للمدير (يضبطها المدير)
  salary    Int? // الراتب الشهري
  shiftStart String? // بداية الدوام HH:MM
  shiftEnd   String? // نهاية الدوام HH:MM
  entryGraceMin Int? @default(0) // سماحية الدخول (دقائق)
  exitGraceMin  Int? @default(0) // سماحية الخروج (دقائق)
  lateRatePerMin     Int? @default(0) // سعر دقيقة الخصم (تأخير/خروج مبكّر)
  overtimeRatePerMin Int? @default(0) // سعر دقيقة الإضافي
  paidLeavesPerMonth Int? @default(0) // عدد إجازات الراتب المسموحة شهرياً
  missedCheckoutPenalty Int? @default(0) // غرامة نسيان بصمة الخروج (يضبطها المدير)
  bioCredId String? // معرّف بصمة الجهاز (WebAuthn) لتأكيد البصمة ببصمة الهاتف الحقيقية
  // تتبع الموقع بالطلب — لا سجل تاريخي: صف واحد يُستبدل بكل تحديث ويُمسح نهائياً عند الإيقاف
  trackReqAt DateTime? // آخر نبضة طلب تتبع من صفحة التتبع (طازجة = تتبع فعّال؛ قديمة = خمول)
  trackLat   Float? // آخر موقع (يُستبدل كل دقيقة)
  trackLng   Float?
  trackAt    DateTime? // وقت آخر تحديث موقع
  fcmToken  String? // رمز جهاز FCM (التطبيق الأصلي) — لإيقاظ الخدمة عند طلب التتبع
  isDeleted Boolean  @default(false)
  createdAt DateTime @default(now())

  updatedAt DateTime @default(now()) @updatedAt // تتبّع التغييرات للمزامنة
  @@index([towerId])
  @@index([supportTowerId])
  @@index([agentId])
  @@map("technicians")
}

// ===== حضور الفنيين (بصمات دخول/خروج) — تطبيق إدارة الفنيين =====
model Attendance {
  id           Int       @id @default(autoincrement())
  technicianId Int
  agentId      Int? // عزل الوكيل
  towerId      Int?
  dayKey       String? // YYYY-MM-DD (توقيت بغداد) — يوم واحد لكل فني
  checkIn      DateTime? // بصمة الدخول (وقت الخادم)
  checkOut     DateTime? // بصمة الخروج
  checkoutBy   String? // tech | manager (بصمة خروج يدوية من المدير)
  checkOutTowerId Int? // مكتب بصمة الخروج إن اختلف عن مكتب الدخول (دعم يوم طُلب بعد بصمة الدخول بالمكتب الأصلي)
  lateExcuse   String? // طلب «نسيت البصمة» عند الدخول المتأخّر: null | pending | approved | rejected — pending يُعلّق خصم التأخير حتى قرار المدير
  // المحسوب عند الخروج
  lateMinutes     Int? // دقائق تأخير الدخول (فوق السماحية)
  earlyMinutes    Int? // دقائق الخروج المبكّر
  overtimeMinutes Int? // دقائق الإضافي (فوق نهاية الدوام + السماحية)
  lateDeduction     Int? // خصم التأخير
  earlyDeduction    Int? // خصم الخروج المبكّر
  overtimeAddition  Int? // مبلغ الإضافي
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  @@index([technicianId])
  @@index([agentId])
  @@map("attendances")
}

// ===== إجازات الفنيين — يوم (براتب/بلا حسب الحصّة الشهرية) أو زمنية؛ سبب إلزامي؛ قبول/رفض المدير =====
model Leave {
  id           Int      @id @default(autoincrement())
  technicianId Int
  agentId      Int? // عزل الوكيل
  towerId      Int?
  kind         String // "day" | "time"
  paid         Boolean  @default(false) // إجازة يوم مدفوعة (تُحتسب من الحصّة)
  dayKey       String // YYYY-MM-DD (توقيت بغداد) — يوم الإجازة
  startMin     Int? // إجازة زمنية: بداية الدقيقة من اليوم (بغداد)
  endMin       Int? // إجازة زمنية: نهاية الدقيقة من اليوم
  reason       String // إلزامي
  status       String   @default("pending") // pending | approved | rejected
  decidedBy    String? // اسم المدير الذي قرّر
  decidedAt    DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @default(now()) @updatedAt

  @@index([technicianId])
  @@index([agentId])
  @@index([dayKey])
  @@map("leaves")
}

// ===== ذمم الفنيين (عهدة المواد) — كمية من مادة بحوزة فني، لا تُنقِص إجمالي المخزن =====
// المتبقي الكلي = Item.count ؛ بالمكتب = count − مجموع العهد ؛ يم الفني = العهدة.
model Custody {
  id           Int     @id @default(autoincrement())
  technicianId Int
  itemId       Int
  towerId      Int? // المكتب (لعزل الذمم لكل مكتب)
  qty          Float   @default(0)
  isDeleted    Boolean @default(false)

  updatedAt DateTime @default(now()) @updatedAt // تتبّع التغييرات للمزامنة
  @@index([technicianId])
  @@index([itemId])
  @@map("custodies")
}

model TaskList {
  id          Int      @id @default(autoincrement())
  boardId     Int // اللوحة المالكة
  name        String
  position    Int      @default(0)
  timeTracked Boolean  @default(false) // عمود محسوب بالوقت — تجاوز وقت الفئة يولّد خصماً معلّقاً
  isDeleted   Boolean  @default(false)

  updatedAt DateTime @default(now()) @updatedAt // تتبّع التغييرات للمزامنة
  @@index([boardId])
  @@map("task_lists")
}

model TaskCard {
  id           Int       @id @default(autoincrement())
  listId       Int // العمود المالك
  title        String
  description  String?
  assignee     String? // اسم الفني/الموظف (للعرض)
  technicianId Int? // الفني المسؤول (لتجميع التحصيل)
  subscriberId Int? // المشترك المصدر (لبطاقات العمليات) — لمنع بطاقتين فعّالتين لنفس المشترك
  kind         String    @default("maintenance") // maintenance = صيانة | delivery = توصيل
  label        String? // لون/تصنيف
  dueDate      DateTime?
  position     Int       @default(0)
  done         Boolean   @default(false)
  // دورة حياة البطاقة
  startedAt    DateTime? // وقت ضغط الفني «بدء» (يُخفى المحتوى قبله ويبدأ احتساب المدة)
  durationSec  Int? // مدة الإنجاز بالثواني (completedAt − startedAt)
  postponedTo  DateTime? // موعد التأجيل (عند عدم تواجد المشترك)
  // بيانات الإنجاز
  serviceDetails String? // تفاصيل الصيانة
  techNote      String? // ملاحظة يكتبها الفني على البطاقة (تُعرض على وجهها)
  amount        Float? // المبلغ المستلم من الزبون
  materialsInfo String? // JSON بالمواد المباعة من الذمم (للعرض)
  completedAt   DateTime?
  settled       Boolean   @default(false) // تمّ التحصيل (اكمال)
  archivedAt    DateTime? // وقت الأرشفة (بعد التحصيل) — تبقى بالأرشيف أسبوعاً ثم تُحذف نهائياً
  history       String? // سجل تغييرات البطاقة JSON [{at,by,text}] (تأجيل/تحويل/نقل…)
  createdAt    DateTime  @default(now())
  isDeleted    Boolean   @default(false)

  updatedAt DateTime @default(now()) @updatedAt // تتبّع التغييرات للمزامنة
  @@index([listId])
  @@index([technicianId])
  @@index([archivedAt])
  @@index([subscriberId])
  @@map("task_cards")
}

// صورة إنجاز البطاقة (base64) — مفصولة لتفادي تضخّم استعلام اللوحة، وتُحذف فعلياً مع البطاقة/التحصيل
model CardPhoto {
  id        Int      @id @default(autoincrement())
  cardId    Int      @unique
  data      String // data URL (JPEG مضغوط)
  createdAt DateTime @default(now())

  updatedAt DateTime @default(now()) @updatedAt // تتبّع التغييرات للمزامنة
  @@map("card_photos")
}

// جلسة واتساب كل مكتب منشورة في السحابة — ينشرها الوكيل ليقرأها الموقع (لعرض QR من الإنترنت)
// مُرحِّل عمليات واتساب بين الموقع (Vercel، بلا عميل) والوكيل (يملك العميل الحيّ).
// الموقع ينشئ طلباً (pending)، الوكيل القائد ينفّذه ويكتب النتيجة، الموقع يقرؤها.
model WaRelay {
  id        Int      @id @default(autoincrement())
  towerId   Int
  kind      String // chats | messages | send | logout
  params    String? // JSON: { chatId?, text?, limit? }
  status    String   @default("pending") // pending | done | error
  result    String? // JSON نتيجة التنفيذ
  error     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@index([status, createdAt])
  @@map("wa_relays")
}

// نقاط الخريطة (أعمدة المنطقة) — مرجع ثابت: اسم العمود ← إحداثيات. تُستورَد مرّة من ملف KMZ.
model MapPoint {
  name String  @id // مثل F2/1/MWA
  lat  Float
  lng  Float

  @@map("map_points")
}

// رمز تنصيب لمرّة واحدة — يُسلّم رابط قاعدة البيانات للمُنصِّب بأمان (بلا إدخال يدوي ولا سكربت عام)
// ===== سجل مكافآت المشتركين (منح/استخدام) =====
model RewardLog {
  id            Int      @id @default(autoincrement())
  agentId       Int? // الوكيل (المستأجر) — للعزل والنسخ الاحتياطي
  towerId       Int? // مكتب العملية
  subscriberId  Int?
  kind          String // grant = منح عند التفعيل، redeem = استخدام/خصم
  amount        Int // المبلغ الممنوح أو المخصوم
  code          String? // الكود المرتبط بالعملية
  context       String? // activation | maintenance | sale
  refId         Int? // معرّف الوصل/البطاقة/البيع المرتبط
  balanceAfter  Int? // الرصيد بعد العملية
  subscriberName String? // اسم المشترك (للعرض في السجل)
  createdByUser String?
  createdByName String?
  createdAt     DateTime @default(now())

  @@index([agentId])
  @@index([subscriberId])
  @@map("reward_logs")
}

model InstallToken {
  token     String   @id
  agentId   Int? // الوكيل الذي أنشأ الرمز
  createdBy Int? // معرّف المستخدم المنشئ
  expiresAt DateTime // تنتهي صلاحيته (نصف ساعة)
  usedAt    DateTime? // وقت أول استخدام (لمرّة واحدة)
  createdAt DateTime @default(now())

  @@map("install_tokens")
}

// ===== أوامر الطباعة الصامتة =====
// يُنشأ أمر عند فتح/طباعة وصل من أي جهاز، ويلتقطه العامل المحلي بحاسبة المكتب
// فيولّد PDF الوصل ويطبعه بصمت على الطابعة الافتراضية (بلا نافذة حوار إطلاقاً).
model PrintJob {
  id        Int       @id @default(autoincrement())
  agentId   Int? // الوكيل (عزل المستأجر)
  towerId   Int? // مكتب الطابعة (مكتب الوصل)
  kind      String // subscription | invoice
  refId     Int // معرّف الوصل (subscriptionEntry.id أو invoice.id)
  status    String    @default("pending") // pending | printing | done | failed
  error     String?
  createdAt DateTime  @default(now())
  doneAt    DateTime?

  updatedAt DateTime @default(now()) @updatedAt
  @@index([status, createdAt])
  @@map("print_jobs")
}

model WaSession {
  towerId     Int       @id // المكتب
  state       String    @default("disconnected") // disconnected|starting|qr|authenticated|ready|error
  qr          String? // نص الـQR الخام (يحوّله الموقع لصورة)
  error       String?
  requestedAt DateTime? // طلب اتصال من الموقع (يلتقطه الوكيل ويبدأ التشغيل)
  // مالكة الجلسة الحصرية (MACHINE_ID لحاسبةٍ وصلت ready): أي حاسبة أخرى تحمل نسخة
  // قديمة من هذه الجلسة تحذفها ذاتياً — يمنع تقاتل حاسبتين على نفس الجلسة (إبطال واتساب)
  hostMachineId String?
  updatedAt   DateTime  @updatedAt

  @@map("wa_sessions")
}

// حواسيب المكاتب المُسجَّلة في النظام الهجين (العمّال) — للأولوية وانتخاب القائد (مضيف واتساب)
model HybridWorker {
  id        Int      @id @default(autoincrement())
  machineId  String  @unique // معرّف ثابت للحاسبة (يولّده المُنصِّب)
  agentId    Int? // الوكيل المالك للحاسبة — تُحدَّد عند اعتماد المدير؛ عزل جلسات الواتساب لكل وكيل
  name       String? // اسم الجهاز التلقائي (hostname) — تكتبه نبضة العامل
  displayName String? // الاسم الذي يحدّده المدير — لا تلمسه النبضة (يمنع رجوعه للاسم القديم)
  approved   Boolean @default(false) // لا تصبح جزءاً فعّالاً من النظام الهجين إلا بموافقة المدير
  blocked    Boolean @default(false) // محظورة: حذفها المدير — تُخفى من اللوحة ويتوقّف عاملها إن اكتشفها
  nodeNumber Int? // رقم العقدة في نظام المعرّفات المُنطَّقة (السحابة=0، الحواسيب 1..)؛ نطاقها = nodeNumber×10^8
  towerId    Int? // المكتب التابع له (اختياري)
  priority  Int      @default(100) // الأصغر = أعلى أولوية ليكون القائد
  lastSeen  DateTime @default(now()) // آخر نبضة heartbeat
  createdAt DateTime @default(now())

  updatedAt DateTime @default(now()) @updatedAt // تتبّع التغييرات للمزامنة
  @@map("hybrid_workers")
}

// أنواع البطاقات (توصيل/تحويل/اعادة/صيانة/تنصيب + أنواع يضيفها المستخدم)
// deliveryOnly = بطاقة مبلغ فقط (كالتوصيل) لا تتطلّب تفاصيل/صورة عند الإنجاز.
model CardType {
  id              Int     @id @default(autoincrement())
  agentId         Int? // الوكيل (المستأجر) مالك هذا الإعداد
  name            String
  deliveryOnly    Boolean @default(false)
  execMinutes     Int? // الوقت المسموح لإنجاز هذا النوع (دقائق) — أساس احتساب التجاوز
  overrunDeduction Int? // خصم لكل دقيقة تجاوز فوق الوقت المسموح
  position        Int     @default(0)
  isDeleted       Boolean @default(false)

  updatedAt DateTime @default(now()) @updatedAt // تتبّع التغييرات للمزامنة
  @@map("card_types")
}

// ===== خصومات/مكافآت الفني المعلّقة — تجاوز وقت البطاقة يولّد خصماً معلّقاً يؤكّده/يرفضه المدير =====
model Adjustment {
  id           Int       @id @default(autoincrement())
  technicianId Int
  agentId      Int? // عزل الوكيل
  towerId      Int?
  kind         String // "deduction" خصم | "bonus" مكافأة
  source       String // "overrun" تجاوز وقت | "manual" يدوي
  amount       Int // موجب دائماً؛ النوع يحدّد الاتجاه
  reason       String
  cardId       Int? // البطاقة المسبّبة (لتجاوز الوقت)
  overrunMin   Int? // دقائق التجاوز (توثيق)
  status       String    @default("pending") // pending | confirmed | rejected
  dayKey       String // YYYY-MM-DD (بغداد) — للتجميع الشهري في الرواتب
  decidedBy    String?
  decidedAt    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @default(now()) @updatedAt

  @@index([technicianId])
  @@index([agentId])
  @@index([status])
  @@map("adjustments")
}

// ===== كشف راتب مؤرشَف — لقطة مضغوطة عند التسديد؛ يُصفَّر بعدها سجل الفني الخام =====
model SalaryStatement {
  id                   Int      @id @default(autoincrement())
  technicianId         Int
  technicianName       String
  agentId              Int? // عزل الوكيل
  towerId              Int?
  periodFrom           String // dayKey أول سجل محتسب
  periodTo             String // dayKey التسديد
  daysPaid             Int // أيام محتسبة (حضور + إجازة براتب)
  dailyAmount          Int // متوسط مبلغ اليوم
  baseEarned           Int // مجموع مبالغ الأيام
  overtime             Int // مجموع الإضافي
  bonuses              Int // مجموع المكافآت المؤكّدة
  attendanceDeductions Int // خصومات التأخير/الخروج المبكّر
  confirmedDeductions  Int // خصومات معلّقة مؤكّدة (تجاوز الوقت…)
  net                  Int // الصافي المدفوع
  details              String // JSON بالبنود المؤثّرة (تاريخ/نوع/مبلغ/سبب)
  paidByUser           String?
  moneyTxId            Int? // قيد الصرف المرتبط
  createdAt            DateTime @default(now())

  @@index([technicianId])
  @@index([agentId])
  @@map("salary_statements")
}

// ===== إشعارات المدير — أحداث الفنيين (بصمة/إجازة/خصم معلّق) =====
model Notification {
  id        Int      @id @default(autoincrement())
  agentId   Int? // عزل الوكيل
  towerId   Int? // مكتب الحدث
  type      String // checkin | checkout | leave | deduction
  title     String
  body      String
  refType   String? // technician | leave | adjustment
  refId     Int?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([agentId])
  @@index([towerId])
  @@index([read])
  @@map("notifications")
}

// ===== اشتراكات Web Push للمدير (VAPID) =====
model PushSubscription {
  id        Int      @id @default(autoincrement())
  userId    Int // المستخدم المشترِك (المدير)
  agentId   Int? // للعزل والاستهداف
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([agentId])
  @@map("push_subscriptions")
}

// سجل صيانات المشترك (بجانب سجل الوصولات) — تفاصيل الصيانة من الفني وتاريخها؛ بلا صور.
model MaintenanceLog {
  id             Int      @id @default(autoincrement())
  subscriberId   Int
  details        String
  technicianName String?
  cardTitle      String?
  kind           String? // نوع البطاقة (صيانة/تنصيب...)
  durationSec    Int? // مدة إنجاز الفني للبطاقة بالثواني
  amount         Float? // مبلغ البطاقة المستلم من المشترك
  date           DateTime @default(now())
  createdAt      DateTime @default(now())

  updatedAt DateTime @default(now()) @updatedAt // تتبّع التغييرات للمزامنة
  @@index([subscriberId])
  @@map("maintenance_logs")
}
